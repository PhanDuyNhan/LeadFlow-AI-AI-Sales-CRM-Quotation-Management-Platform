# ─────────────────────────────────────────────────────────────
# LeadFlow AI — Frontend environment template
# Copy this file to `.env` and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to the browser.
# NEVER put secrets here — anything in here ships to the client.
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (note the `/api` suffix — every request is
# prefixed with it).
#  - Local:       http://localhost:5000/api
#  - Production:  set to your deployed backend URL, e.g.
#                 https://leadflow-api.onrender.com/api
# In Vercel, add this as an Environment Variable named VITE_API_URL for the
# Production (and Preview) environments, then redeploy so the build picks it up.
VITE_API_URL=http://localhost:5000/api
