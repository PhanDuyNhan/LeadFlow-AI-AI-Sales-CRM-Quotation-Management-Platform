# ─────────────────────────────────────────────────────────────
# LeadFlow AI — Backend environment template
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (it is git-ignored). Do not put real secrets here.
# ─────────────────────────────────────────────────────────────

# Runtime environment: `development` locally, `production` on Render/Railway.
NODE_ENV=development

# Port the API listens on. Render/Railway inject their own PORT — read it from env.
PORT=5000

# MongoDB connection string.
#  - Local:  mongodb://localhost:27017/leadflow
#  - Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/leadflow?retryWrites=true&w=majority
MONGO_URI=

# Secret used to sign JWTs. Use a long, random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# How long an issued token stays valid (e.g. 7d, 24h, 30m).
JWT_EXPIRES_IN=7d

# Allowed frontend origin for CORS.
#  - Local:       http://localhost:5173
#  - Production:  set this to your deployed frontend URL, e.g. https://leadflow-ai.vercel.app
#                 (must match exactly — no trailing slash). Update it whenever the
#                 Vercel domain changes, otherwise the browser will block API calls.
CLIENT_URL=http://localhost:5173
